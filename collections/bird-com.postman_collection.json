    {
      "id": "b1f0a001-0001-4001-8001-000000000006",
      "name": "Legacy MessageBird",
      "description": {"content": "Predecessor MessageBird REST API at rest.messagebird.com.", "type": "text/plain"},
      "item": [
        {
          "id": "b1f0a001-0001-4001-8001-000000000601",
          "name": "(Legacy) Send an SMS message",
          "request": {
            "name": "(Legacy) Send an SMS message",
            "description": {},
            "url": {
              "raw": "{{legacyBaseUrl}}/messages",
              "path": ["messages"],
              "host": ["{{legacyBaseUrl}}"]
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"originator\": \"Bird\",\n  \"recipients\": [\"+15551234567\"],\n  \"body\": \"Hello from MessageBird\"\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "response": []
        },
