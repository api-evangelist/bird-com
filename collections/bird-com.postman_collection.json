      "item": [
        {
          "id": "b1f0a001-0001-4001-8001-000000000101",
          "name": "Send a message",
          "request": {
            "name": "Send a message",
            "description": {
              "content": "Send a message over an active channel. Requires a receiver and either a body or a template.",
              "type": "text/plain"
            },
            "url": {
              "raw": "{{baseUrl}}/workspaces/:workspaceId/channels/:channelId/messages",
              "path": ["workspaces", ":workspaceId", "channels", ":channelId", "messages"],
              "host": ["{{baseUrl}}"],
              "query": [],
              "variable": [
                {"key": "workspaceId", "value": "<string>"},
                {"key": "channelId", "value": "<string>"}
              ]
            },
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Accept", "value": "application/json"}
            ],
            "method": "POST",
            "auth": null,
            "body": {
              "mode": "raw",
              "raw": "{\n  \"receiver\": {\n    \"contacts\": [\n      { \"identifierValue\": \"+15551234567\", \"identifierKey\": \"phonenumber\" }\n    ]\n  },\n  \"body\": {\n    \"type\": \"text\",\n    \"text\": { \"text\": \"Hello from Bird\" }\n  }\n}",
              "options": {"raw": {"language": "json"}}
            }
          },
          "response": []
        },
        {
          "id": "b1f0a001-0001-4001-8001-000000000102",
